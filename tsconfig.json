{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "types": ["bun"],
    "paths": {
      "@vizen/core": ["./packages/core/src/index.ts"],
      "@vizen/core/*": ["./packages/core/src/*"],
      "@vizen/runtime": ["./packages/runtime/src/index.ts"],
      "@vizen/runtime/*": ["./packages/runtime/src/*"],
      "@vizen/ui": ["./packages/ui/src/index.ts"],
      "@vizen/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "vitest.config.ts", "types/**/*.d.ts"]
}
