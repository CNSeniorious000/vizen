{
  "name": "zensical-vite",
  "version": "0.0.1",
  "description": "A modern static site generator — TS port of zensical with Vite-powered HMR and client-side navigation",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run --filter=./packages/* --filter=. dev",
    "build": "tsc -b && bun run build:all",
    "build:all": "bun run --filter=./packages/* build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
